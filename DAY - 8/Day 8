stering)\")\n","plt.grid(True)\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":552},"id":"MTC4ufNxbcIk","executionInfo":{"status":"ok","timestamp":1781781098636,"user_tz":-330,"elapsed":940,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"34d43701-0096-4153-b788-9cfdf206a153"},"execution_count":55,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 127919 (\\N{DIRECT HIT}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 700x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Test different k values and calculate inertia (sum of squared distances to cluster centers)\n","inertias = []\n","K = range(1, 11)\n","\n","for k in K:\n","    kmeans = KMeans(n_clusters=k, n_init=10, random_state=42)\n","    kmeans.fit(X)\n","    inertias.append(kmeans.inertia_)\n","\n","# Plot elbow graph\n","plt.figure(figsize=(8, 5))\n","plt.plot(K, inertias, marker='o')\n","plt.title(\"📉 Elbow Method - Choosing Optimal k\")\n","plt.xlabel(\"Number of Clusters (k)\")\n","plt.ylabel(\"Inertia (Within Cluster Sum of Squares)\")\n","plt.grid(True)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":552},"id":"PYbuQfA_betM","executionInfo":{"status":"ok","timestamp":1781781113007,"user_tz":-330,"elapsed":1075,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"3af6f611-2f3b-43b9-cc45-251a5b64bd3e"},"execution_count":56,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 128201 (\\N{CHART WITH DOWNWARDS TREND}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Fit model with optimal number of clusters\n","kmeans_model = KMeans(n_clusters=4, n_init=10, random_state=42)\n","cluster_labels = kmeans_model.fit_predict(X)\n","\n","# Add cluster labels to DataFrame\n","df[\"Cluster\"] = cluster_labels\n"],"metadata":{"id":"GAYRPP3VbiLK","executionInfo":{"status":"ok","timestamp":1781781146676,"user_tz":-330,"elapsed":44,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}}},"execution_count":57,"outputs":[]},{"cell_type":"code","source":["# Visualize clusters with centroids\n","plt.figure(figsize=(7, 5))\n","sns.scatterplot(data=df, x=\"Feature_1\", y=\"Feature_2\", hue=\"Cluster\", palette=\"viridis\", s=60)\n","centers = kmeans_model.cluster_centers_\n","plt.scatter(centers[:, 0], centers[:, 1], c='red', s=200, marker='X', label='Centroids')\n","plt.title(\"📊 K-Means Clustering Results with k=4\")\n","plt.legend()\n","plt.grid(True)\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":532},"id":"5brmU9y9bqoz","executionInfo":{"status":"ok","timestamp":1781781158025,"user_tz":-330,"elapsed":423,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"5c02b51e-8d5c-47e4-e17b-d1c0f07f03ea"},"execution_count":58,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 128202 (\\N{BAR CHART}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 700x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Calculate Silhouette Score (range: -1 to 1), higher is better\n","score = silhouette_score(X, cluster_labels)\n","print(f\"✅ Silhouette Score for k=4: {score:.4f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"X5rbzX8WbtVB","executionInfo":{"status":"ok","timestamp":1781781170018,"user_tz":-330,"elapsed":53,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"66f0c240-f1f0-4668-e8df-8e9ef0ce7de5"},"execution_count":59,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Silhouette Score for k=4: 0.7519\n"]}]},{"cell_type":"code","source":["print(\"\\n📌 Summary:\")\n","print(f\"✔️ Optimal k (from elbow method): 4\")\n","print(f\"✔️ Silhouette Score indicates how well-separated clusters are: {score:.4f}\")\n","print(\"✔️ Red 'X' markers represent cluster centroids.\")\n","print(\"✔️ You can try different 'k' values and observe how clusters change.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"JX0J7AZVbwWf","executionInfo":{"status":"ok","timestamp":1781781181953,"user_tz":-330,"elapsed":21,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"fe8057ef-f782-4c5e-b284-7588b19370bb"},"execution_count":60,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","📌 Summary:\n","✔️ Optimal k (from elbow method): 4\n","✔️ Silhouette Score indicates how well-separated clusters are: 0.7519\n","✔️ Red 'X' markers represent cluster centroids.\n","✔️ You can try different 'k' values and observe how clusters change.\n"]}]},{"cell_type":"markdown","source":["# **Clustering**"],"metadata":{"id":"MMvvJPUcclAT"}},{"cell_type":"code","source":["\n","\n","# === SETUP: load the provided file (regenerate it if missing) ===\n","import os\n","import numpy as np\n","import pandas as pd\n","\n","\n","def build_regimes(csv_path=\"machine_operating_data.csv\", seed=180, verbose=False):\n","    \"\"\"CNC machine operating telemetry — UNLABELLED readings to be clustered into\n","    operating regimes (e.g. idle / roughing / finishing / heavy-cut). Built with a few\n","    genuine latent regimes so k-means has real structure to recover, plus features on\n","    very different scales (scaling lesson) for the U18 clustering lab.\n","\n","    Features:\n","      spindle_rpm        spindle speed (rev/min)\n","      feed_rate_mmpm     feed rate (mm/min)\n","      cut_depth_mm       depth of cut (mm)\n","      power_kw           spindle power (kW)\n","      vibration_mm_s     vibration (mm/s)\n","      coolant_lpm        coolant flow (L/min)\n","      tool_temp_c        tool temperature (deg C)\n","    No label column (the 'regime' is what clustering should discover).\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    # latent regimes: (rpm, feed, depth, power, vib, coolant, temp), weight\n","    regimes = [\n","        (\"idle\",      (700,   0,    0.0,  1.5,  0.6, 2,   28), 0.20),\n","        (\"roughing\",  (1500,  400,  3.5,  18,   5.5, 25,  62), 0.30),\n","        (\"finishing\", (3000,  180,  0.6,  9,    2.2, 18,  48), 0.30),\n","        (\"heavy_cut\", (1100,  600,  6.0,  26,   8.5, 30,  78), 0.20),\n","    ]\n","    N = 1500\n","    rows = []\n","    for name, mu, w in regimes:\n","        n = int(N * w)\n","        spread = np.array([120, 50, 0.4, 2.0, 0.7, 3, 5])\n","        block = rng.normal(mu, spread, size=(n, 7))\n","        rows.append(block)\n","    X = np.vstack(rows)\n","    X[:, :] = np.clip(X, 0, None)\n","    rng.shuffle(X)\n","\n","    df = pd.DataFrame(X, columns=[\n","        \"spindle_rpm\", \"feed_rate_mmpm\", \"cut_depth_mm\", \"power_kw\",\n","        \"vibration_mm_s\", \"coolant_lpm\", \"tool_temp_c\"])\n","    df[\"spindle_rpm\"] = df.spindle_rpm.round(0).astype(int)\n","    df[\"feed_rate_mmpm\"] = df.feed_rate_mmpm.round(0).astype(int)\n","    for c in [\"cut_depth_mm\", \"power_kw\", \"vibration_mm_s\", \"tool_temp_c\"]:\n","        df[c] = df[c].round(2)\n","    df[\"coolant_lpm\"] = df.coolant_lpm.round(1)\n","    df.to_csv(csv_path, index=False)\n","    if verbose:\n","        print(\"regimes:\", df.shape)\n","        print(\"feature ranges (max-min):\")\n","        print((df.max() - df.min()).round(1).to_string())\n","        print(\"(built from 4 latent regimes; no label column kept)\")\n","    return df\n","\n","if not os.path.exists('machine_operating_data.csv'):\n","    build_regimes(); print('Generated dataset file.')\n","else:\n","    print('Found the provided dataset file.')\n","\n","\n","import pandas as pd, numpy as np, matplotlib.pyplot as plt, seaborn as sns\n","sns.set_theme(style='whitegrid')\n","df = pd.read_csv('machine_operating_data.csv')\n","print('readings:', df.shape)\n","print('feature ranges (max-min) — note how different they are:')\n","print((df.max() - df.min()).round(1).to_string())\n","df.head(3)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":321},"id":"U4441RLKbzQ9","executionInfo":{"status":"ok","timestamp":1781781422308,"user_tz":-330,"elapsed":9,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"2aee293c-86d7-44c3-ff76-e75fc15cee7c"},"execution_count":61,"outputs":[{"output_type":"stream","name":"stdout","text":["Generated dataset file.\n","readings: (1500, 7)\n","feature ranges (max-min) — note how different they are:\n","spindle_rpm       2924.0\n","feed_rate_mmpm     781.0\n","cut_depth_mm         7.1\n","power_kw            31.4\n","vibration_mm_s      10.2\n","coolant_lpm         39.5\n","tool_temp_c         75.6\n"]},{"output_type":"execute_result","data":{"text/plain":["   spindle_rpm  feed_rate_mmpm  cut_depth_mm  power_kw  vibration_mm_s  \\\n","0         2860             202          0.49      7.78            3.06   \n","1         1373             428          3.60     20.04            6.28   \n","2         3031             237          0.36     12.23            3.17   \n","\n","   coolant_lpm  tool_temp_c  \n","0         20.3        42.31  \n","1         29.1        61.35  \n","2         14.1        47.21  "],"text/html":["\n","  <div id=\"df-0a0b3a07-52f7-4941-8eb5-3e0c6f32a065\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-