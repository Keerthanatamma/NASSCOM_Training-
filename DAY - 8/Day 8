 overfit if grown too deep.\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 1B. TRAIN vs TEST F1 ACROSS DEPTH (the overfitting curve)\n","# -----------------------------------------------------------\n","depths = range(1, 16); tr, te = [], []\n","for d in depths:\n","    m = Pipeline([('prep', pre), ('clf', DecisionTreeClassifier(max_depth=d, random_state=0))]).fit(X_train, y_train)\n","    tr.append(f1_score(y_train, m.predict(X_train)))\n","    te.append(f1_score(y_test, m.predict(X_test)))\n","fig, ax = plt.subplots(figsize=(7, 4))\n","ax.plot(list(depths), tr, 'o-', label='train', color='#2D6A9F')\n","ax.plot(list(depths), te, 'o-', label='test', color='#C0392B')\n","ax.set_xlabel('max_depth'); ax.set_ylabel('F1'); ax.set_title('Train rises, test peaks then falls')\n","ax.legend(); plt.tight_layout(); plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":401},"id":"PcTiUyrbVJKj","executionInfo":{"status":"ok","timestamp":1781762668969,"user_tz":-330,"elapsed":973,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"9c5495ba-0d1b-4de4-e980-cf7c0c9cd295"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["best_depth = depths[np.argmax(te)]\n","\n","print(\"Best depth:\", best_depth)\n","\n","tree_best = Pipeline([\n","    ('prep', pre),\n","    ('clf', DecisionTreeClassifier(\n","        max_depth=best_depth,\n","        random_state=0\n","    ))\n","])\n","\n","tree_best.fit(X_train, y_train)\n","\n","pred = tree_best.predict(X_test)\n","\n","print(\"Test F1:\", round(f1_score(y_test, pred),3))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"xZ7e5MJFVLRa","executionInfo":{"status":"ok","timestamp":1781762753394,"user_tz":-330,"elapsed":55,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"236f38fc-3c00-41c6-9049-5e52415ef818"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Best depth: 14\n","Test F1: 0.39\n"]}]},{"cell_type":"code","source":["# Find depth with highest test F1\n","best_depth = depths[np.argmax(te)]\n","\n","print(\"Best max_depth:\", best_depth)\n","print(\"Peak Test F1:\", round(max(te), 3))\n","\n","# Refit decision tree with best depth\n","best_tree = Pipeline([\n","    ('prep', pre),\n","    ('clf', DecisionTreeClassifier(\n","        max_depth=best_depth,\n","        random_state=0\n","    ))\n","])\n","\n","best_tree.fit(X_train, y_train)\n","\n","# Predictions\n","y_pred = best_tree.predict(X_test)\n","\n","# Test F1\n","print(\"Refit Tree Test F1:\", round(f1_score(y_test, y_pred), 3))\n","\n","# Comment:\n","# As tree depth increases, training F1 usually continues to improve,\n","# but test F1 eventually stops improving and may decrease.\n","# The widening gap between train and test performance indicates\n","# overfitting: the tree is memorizing training data rather than\n","# learning patterns that generalize to unseen welds."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6_lba6K3VgG4","executionInfo":{"status":"ok","timestamp":1781762785014,"user_tz":-330,"elapsed":15,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"f5b4386c-c821-4eda-8a3c-beaaceeb908b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Best max_depth: 14\n","Peak Test F1: 0.39\n","Refit Tree Test F1: 0.39\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 2A. RANDOM FOREST vs GRADIENT BOOSTING vs ONE TREE\n","# -----------------------------------------------------------\n","from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n","from sklearn.metrics import roc_auc_score\n","def evaluate(model):\n","    pipe = Pipeline([('prep', pre), ('clf', model)]).fit(X_train, y_train)\n","    pred = pipe.predict(X_test); proba = pipe.predict_proba(X_test)[:, 1]\n","    return f1_score(y_test, pred), roc_auc_score(y_test, proba)\n","for name, m in [('DecisionTree', DecisionTreeClassifier(max_depth=4, random_state=0)),\n","                ('RandomForest', RandomForestClassifier(n_estimators=300, random_state=0)),\n","                ('GradientBoosting', GradientBoostingClassifier(random_state=0))]:\n","    f1, auc = evaluate(m)\n","    print(f'{name:18s} F1: {f1:.3f} | ROC-AUC: {auc:.3f}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"d6xygCLiVn09","executionInfo":{"status":"ok","timestamp":1781763029895,"user_tz":-330,"elapsed":3601,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"d55993e4-e2e8-4abb-890c-37055ae240d1"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["DecisionTree       F1: 0.143 | ROC-AUC: 0.625\n","RandomForest       F1: 0.312 | ROC-AUC: 0.666\n","GradientBoosting   F1: 0.291 | ROC-AUC: 0.663\n"]}]},{"cell_type":"code","source":["# Random Forest uses Bagging:\n","# It trains many decision trees independently (in parallel)\n","# on different bootstrap samples of the data and combines\n","# their predictions through majority voting.\n","\n","# Gradient Boosting uses Boosting:\n","# It trains trees sequentially, where each new tree focuses\n","# on correcting the mistakes made by the previous trees.\n","# The final prediction is a weighted combination of all trees.\n","\n","# Random Forest scored gigher roc-auc"],"metadata":{"id":"2baPY5CyWiup"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 3A. RANDOM-FOREST FEATURE IMPORTANCE\n","# -----------------------------------------------------------\n","rf = Pipeline([('prep', pre), ('clf', RandomForestClassifier(n_estimators=300, random_state=0))]).fit(X_train, y_train)\n","feat_names = rf.named_steps['prep'].get_feature_names_out()\n","imp = pd.Series(rf.named_steps['clf'].feature_importances_, index=feat_names).sort_values()\n","fig, ax = plt.subplots(figsize=(7, 4.2))\n","imp.plot(kind='barh', color='#2D6A9F', ax=ax); ax.set_title('Random-forest feature importance')\n","plt.tight_layout(); plt.show()\n","print('Top drivers:'); print(imp.sort_values(ascending=False).head(4).round(3).to_string())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":509},"id":"9hlsow1xbLQL","executionInfo":{"status":"ok","timestamp":1781764366250,"user_tz":-330,"elapsed":2339,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"a207935b-ea27-4e48-8019-e1c198f28eea"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x420 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Top drivers:\n","num__joint_gap_mm       0.172\n","num__heat_input_kjmm    0.127\n","num__voltage_v          0.124\n","num__gas_flow_lpm       0.123\n"]}]},{"cell_type":"code","source":["from sklearn.inspection import permutation_importance\n","\n","perm = permutation_importance(rf, X_test, y_test,\n","                              scoring='f1',\n","                              random_state=0)\n","\n","perm_imp = pd.Series(\n","    perm.importances_mean,\n","    index=X_test.columns\n",")\n","\n","print(perm_imp.sort_values(ascending=False).head(10))\n","\n","# Plot\n","plt.figure(figsize=(7,4))\n","perm_imp.sort_values().tail(10).plot(kind='barh', color='#2D6A9F')\n","plt.title(\"Permutation Importance (F1)\")\n","plt.xlabel(\"Mean decrease in F1 after shuffling\")\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":579},"id":"OZu3-w_4bpTF","executionInfo":{"status":"ok","timestamp":1781764718232,"user_tz":-330,"elapsed":3804,"user":{"displayName":"Keerthana T","userId":"15423794953