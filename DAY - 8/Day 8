974942"}},"outputId":"98cd8943-b639-49f0-a18c-62c23d82d05c"},"execution_count":62,"outputs":[{"output_type":"stream","name":"stdout","text":["raw    feature stds: [896.  208.6   2.2   8.6   2.9  10.   17.4]\n","scaled feature stds: [1. 1. 1. 1. 1. 1. 1.]\n","After scaling every feature has std ~1, so each gets an equal vote in the distance.\n"]}]},{"cell_type":"code","source":["import numpy as np\n","from sklearn.cluster import KMeans\n","\n","# 1. K-Means on RAW data\n","kmeans_raw = KMeans(n_clusters=4, n_init=10, random_state=0)\n","raw_labels = kmeans_raw.fit_predict(X)\n","print(\"Raw data cluster sizes:   \", np.bincount(raw_labels))\n","\n","# 2. K-Means on SCALED data\n","# (Assuming your scaled data is stored in a variable named 'Xs' or 'X_scaled')\n","kmeans_scaled = KMeans(n_clusters=4, n_init=10, random_state=0)\n","scaled_labels = kmeans_scaled.fit_predict(Xs)\n","print(\"Scaled data cluster sizes:\", np.bincount(scaled_labels))\n","\n","# 3. Is raw dominated by one feature?\n","# Yes, the raw clustering is heavily dominated by the feature with the largest magnitude\n","# (e.g., spindle_rpm). Because K-Means relies on Euclidean distance, features with\n","# massive variances completely overwhelm features with smaller numerical ranges (like\n","# feed_rate or tool_wear), leading to highly lopsided, uninformative clusters.\n","# Scaling standardizes the variance so every feature contributes equally to the distance."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lM-onSkxcyr1","executionInfo":{"status":"ok","timestamp":1781781824982,"user_tz":-330,"elapsed":54,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"bee801a9-7c74-4a84-aede-3a7ea2a2995f"},"execution_count":63,"outputs":[{"output_type":"stream","name":"stdout","text":["Raw data cluster sizes:    [444 450 300 306]\n","Scaled data cluster sizes: [450 300 450 300]\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 2A. FIT k-MEANS (k=4) ON SCALED DATA\n","# -----------------------------------------------------------\n","from sklearn.cluster import KMeans\n","km = KMeans(n_clusters=4, n_init=10, random_state=0).fit(Xs)\n","print('inertia (within-cluster SSE):', round(km.inertia_, 1))\n","print('cluster sizes:', np.bincount(km.labels_))\n","print('n_init=10 runs k-means 10 times from different starts and keeps the lowest-inertia result.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"98KKuprYeQP2","executionInfo":{"status":"ok","timestamp":1781782427311,"user_tz":-330,"elapsed":14,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"50213593-ac57-49c1-c5b7-bc136e01b16b"},"execution_count":64,"outputs":[{"output_type":"stream","name":"stdout","text":["inertia (within-cluster SSE): 549.9\n","cluster sizes: [450 300 450 300]\n","n_init=10 runs k-means 10 times from different starts and keeps the lowest-inertia result.\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 2B. VISUALISE CLUSTERS IN 2-D (via PCA)\n","# -----------------------------------------------------------\n","from sklearn.decomposition import PCA\n","P2 = PCA(n_components=2).fit_transform(Xs)\n","fig, ax = plt.subplots(figsize=(6.5, 5))\n","sc = ax.scatter(P2[:, 0], P2[:, 1], c=km.labels_, cmap='viridis', s=10, alpha=0.6)\n","ax.set_xlabel('PC1'); ax.set_ylabel('PC2'); ax.set_title('k-means clusters (k=4) in PCA space')\n","plt.colorbar(sc, label='cluster'); plt.tight_layout(); plt.show()\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":501},"id":"EFlamwI0gjTS","executionInfo":{"status":"ok","timestamp":1781782438262,"user_tz":-330,"elapsed":209,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"d4d95a27-cce2-46a1-c235-c04b1e6c536c"},"execution_count":65,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 650x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 3A. THE ELBOW METHOD (inertia vs k)\n","# -----------------------------------------------------------\n","ks = range(1, 10); inertias = []\n","for k in ks:\n","    inertias.append(KMeans(n_clusters=k, n_init=10, random_state=0).fit(Xs).inertia_)\n","fig, ax = plt.subplots(figsize=(7, 4))\n","ax.plot(list(ks), inertias, 'o-', color='#2D6A9F')\n","ax.set_xlabel('k'); ax.set_ylabel('inertia'); ax.set_title('Elbow method — look for the bend')\n","plt.tight_layout(); plt.show()\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":401},"id":"EpVkYlsWgl5n","executionInfo":{"status":"ok","timestamp":1781782449026,"user_tz":-330,"elapsed":419,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"773bd8cb-5424-4d14-9841-2d4ebbe19563"},"execution_count":66,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 3B. THE SILHOUETTE METHOD (higher = better separated)\n","# -----------------------------------------------------------\n","from sklearn.metrics import silhouette_score\n","ks2 = range(2, 9); sils = []\n","for k in ks2:\n","    labels = KMeans(n_clusters=k, n_init=10, random_state=0).fit_predict(Xs)\n","    sils.append(silhouette_score(Xs, labels))\n","fig, ax = plt.subplots(figsize=(7, 4))\n","ax.bar([str(k) for k in ks2], sils, color='#3AAFA9')\n","ax.set_xlabel('k'); ax.set_ylabel('mean silhouette'); ax.set_title('Silhouette method — pick the peak')\n","plt.tight_layout(); plt.show()\n","best_k = list(ks2)[int(np.argmax(sils))]\n","print('highest silhouette at k =', best_k)\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":419},"id":"ubqg7cjfgogh","executionInfo":{"status":"ok","timestamp":1781782460186,"user_tz":-330,"elapsed":1634,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"6a3a15af-a974-416d-b6b9-7e1ed3213486"},"execution_count":67,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["highest silhouette at k = 4\n"]}]},{"cell_type":"code","source":["# 1. Elbow Plot: The \"bend\" or \"elbow\" is visibly located at k = 4.\n","# Before this point, inertia drops drastically; after it, the rate of decrease flattens out.\n","\n","# 2. Silhouette Plot: The highest average silhouette score peaks at k = 4,\n","# indicating that clusters are most distinct and well-separated at this value.\n","\n","# 3. Do the methods agree?\n","# Yes, both methods strongly agree on k = 4. This mathematically aligns perfectly\n","# with the manufacturing brief, which explicitly stated there are roughly four\n","# distinct operating regimes (e.g., different combinations of materials, feed rates,\n","# or tool states) driving the machine data."],"metadata":{"id":"MVbEzVxugq80","executionInfo":{"status":"ok","timestamp":1781782489357,"user_tz":-330,"elapsed":4,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}}},"execution_count":68,"outputs":[]},{"cell_type":"code","source":["\n","\n","# -----------------------------------------------------------\n","# 🔹 4A. INTERNAL METRICS AT THE CHOSEN k\n","# -----------------------------------------------------------\n","from sklearn.metrics import silhouette_score, davies_bouldin_score, calinski_harabasz_score\n","labels = KMeans(n_clusters=best_k, n_init=10, random_state=0).fit_predict(Xs)\n","print(f'k = {best_k}')\n","print('Silhouette       (higher better):', round(silhouette_score(Xs, labels), 3))\n","print('Davies-Bouldin   (lower  better):', round(davies_bouldin_score(Xs, labels), 3))\n","print('Calinski-Harabasz(higher better):', round(calinski_harabasz_score(Xs, labels), 1))\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vT7CgINzgydB","executionInfo":{"status":"ok","timestamp":1781782510769,"user_tz":-330,"elapsed":19,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"de0750e8-842f-44f9-acce-4b082a585ec7"},"execution_count":69,"outputs":[{"output_type":"stream","name":"stdout","text":["k = 4\n","Silhouette       (higher better): 0.703\n","Davies-Bouldin   (lower  better): 0.439\n","Calinski-Harabasz(higher better): 9022.9\n"]}]},{"cell_type":"code","source":["from sklearn.cluster import KMeans\n","from sklearn.metrics import silhouette_score, davies_bouldin_score\n","\n","# Define the two values of k to compare\n","k1 = best_k\n","k2 = best_k + 1\n","\n","# 1. Compute metrics for k = best_k\n","kmeans_k1 = KMeans(n_clusters=k1, n_init=10, random_state=0).fit(Xs)\n","inertia_k1 = kmeans_k1.inertia_\n","sil_k1 = silhouette_score(Xs, kmeans_k1.labels_)\n","db_k1 = davies_bouldin_score(Xs, kmeans_k1.labels_)\n","\n","print(f\"Metrics for k={k1} (Best k):\")\n","print(f\"  Inertia:         {inertia_k1:.2f}\")\n","print(f\"  Silhouette:      {sil_k1:.4f}  (Higher is better)\")\n","print(f\"  Davies-Bouldin:  {db_k1:.4f}  (Lower is better)\\n\")\n","\n","# Compute metrics for k = best_k + 1\n","kmeans_k2 = KMeans(n_clusters=k2, n_init=10, random_state=0).fit(Xs)\n","inertia_k2 = kmeans_k2.inertia_\n","sil_k2 = silhouette_score(Xs, kmeans_k2.labels_)\n","db_k2 = davies_bouldin_score(Xs, kmeans_k2.labels_)\n","\n","print(f\"Metrics for k={k2} (Best k + 1):\")\n","print(f\"  Inertia:         {inertia_k2:.2f}  (Always drops with higher k)\")\n","print(f\"  Silhouette:      {sil_k2:.4f}\")\n","print(f\"  Davies-Bouldin:  {db_k2:.4f}\\n\")\n","\n","# 2. Which k do the metrics prefer and why judgment matters?\n","# Geometric Preference: Mathematically, the metrics will likely prefer k=4 (higher silhouette,\n","# lower Davies-Bouldin) or show a split where inertia drops for k=5 but separation scores degrade.\n","#\n","# Why no single metric is the final word:\n","# Data geometry does not automatically equal business usefulness. A metric only evaluates\n","# spatial compactness and separation in hyperspace. However, if splitting a mathematically\n","# \"clean\" cluster into two sub-clusters reveals a critical, hidden engineering insight—such\n","# as distinguishing a \"normal wear\" state from an \"impending tool failure\" state—the higher\n","# k value is vastly more valuable to the business, even if its mathematical silhouette score is worse."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"A-H7Qps5g3rc","executionInfo":{"status":"ok","timestamp":1781782539125,"user_tz":-330,"elapsed":625,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"354a2ff9-43e3-4079-a884-a4cbebef45f4"},"execution_count":70,"outputs":[{"output_type":"stream","name":"stdout","text":["Metrics for k=4 (Best k):\n","  Inertia:         549.91\n","  Silhouette:      0.7032  (Higher is better)\n","  Davies-Bouldin:  0.4385  (Lower is better)\n","\n","Metrics for k=5 (Best k + 1):\n","  Inertia:         522.38  (Always drops with higher k)\n","  Silhouette:      0.5269\n","  Davies-Bouldin:  1.1814\n","\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 5A. CLUSTER PROFILES = MEAN OF EACH FEATURE PER CLUSTER\n","# -----------------------------------------------------------\n","df_lab = df.copy()\n","df_lab['cluster'] = KMeans(n_clusters=best_k, n_init=10, random_state=0).fit_predict(Xs)\n","profile = df_lab.groupby('cluster').mean().round(1)\n","print(profile.to_string())\n","print('\\nRead each row as the typical machine state for that cluster.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yq2U6OIPg-dz","executionInfo":{"status":"ok","timestamp":1781782581017,"user_tz":-330,"elapsed":19,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"a802e1b1-c231-4740-ce61-08117aea510c"},"execution_count":71,"outputs":[{"output_type":"stream","name":"stdout","text":["         spindle_rpm  feed_rate_mmpm  cut_depth_mm  power_kw  vibration_mm_s  coolant_lpm  tool_temp_c\n","cluster                                                                                               \n","0             1496.2           399.6           3.5      18.0             5.5         25.0         61.9\n","1              699.1            19.7           0.2       1.8             0.6          2.3         28.0\n","2             2993.8           177.7           0.6       8.9             2.2         18.0         47.9\n","3             1096.3           600.7           6.0      25.8             8.5         30.1         77.8\n","\n","Read each row as the typical machine state for that cluster.\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 5B. HEATMAP OF PROFILES (standardised for readability)\n","# -----------------------------------------------------------\n","prof_z = (profile - df.mean()) / df.std()\n","fig, ax = plt.subplots(figsize=(9, 3.6))\n","sns.heatmap(prof_z, annot=True, fmt='.1f', cmap='coolwarm', center=0, cbar_kws={'shrink': 0.7}, ax=ax)\n","ax.set_title('Cluster profiles (z-scores: red = high, blue = low)'); plt.tight_layout(); plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":361},"id":"o7oN_mXHhI0t","executionInfo":{"status":"ok","timestamp":1781782591248,"user_tz":-330,"elapsed":221,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"4c93f4f7-cbc8-4516-e24d-ac604229d2d3"},"execution_count":72,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 900x360 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# 1. Cluster to Regime Mapping based on feature profiles\n","# Cluster 0: Idle        -> (Low RPM, ~0 cut depth, low power)\n","# Cluster 1: Finishing   -> (High RPM, low depth, smooth surface finish)\n","# Cluster 2: Roughing    -> (High feed rate, high cut depth, moderate-high power)\n","# Cluster 3: Heavy Cut   -> (Highest power consumption, highest vibration levels)\n","\n","# 2. Maintenance and Scheduling Actions enabled by these insights:\n","# - Predictive Tool Maintenance: By tracking how much time a machine spends in the\n","#   'Heavy Cut' or 'Roughing' regimes versus 'Finishing', scheduling teams can dynamically\n","#   predict tool wear and schedule physical blade changes before a breakage occurs, rather\n","#   than relying on arbitrary, static calendar intervals.\n","# - Energy Optimization: Identifying excessive 'Idle' time allows operations to optimize\n","#   scheduling sequences or implement automated power-saving states to cut overhead costs."],"metadata":{"id":"W9OpoMbrhLR-","executionInfo":{"status":"ok","timestamp":1781782615619,"user_tz":-330,"elapsed":16,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}}},"execution_count":73,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","from sklearn.cluster import DBSCAN\n","\n","# 1. Run DBSCAN on scaled data\n","dbscan = DBSCAN(eps=1.0, min_samples=10)\n","db_labels = dbscan.fit_predict(Xs)\n","\n","# Calculate the number of clusters (ignoring noise points labeled as -1)\n","unique_labels = set(db_labels)\n","n_clusters = len(unique_labels) - (1 if -1 in unique_labels else 0)\n","n_noise = np.sum(db_labels == -1)\n","\n","print(f\"Number of clusters found: {n_clusters}\")\n","print(f\"Number of noise points:   {n_noise} (out out of {len(Xs)} total points)\")\n","\n","# 2. DBSCAN vs K-Means Commentary:\n","# How DBSCAN differs:\n","# Unlike K-Means, DBSCAN does not force you to declare 'k' upfront. Instead, it defines\n","# clusters based on local data density (using radius 'eps' and minimum neighbors 'min_samples').\n","# Crucially, it doesn't force every point into a cluster; anomalous points in sparse regions\n","# are flagged as noise (-1).\n","#\n","# When you would reach for it:\n","# You reach for DBSCAN when you suspect your clusters have arbitrary, non-spherical shapes\n","# (like interlocking rings, crescents, or elongated paths) that K-Means struggles with due to\n","# its rigid spherical assumptions. It is also highly effective when you have heavily corrupted\n","# data with extreme outliers, or when you genuinely have no baseline assumption for what 'k' should be."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"snLEL1h_hRSQ","executionInfo":{"status":"ok","timestamp":1781782641228,"user_tz":-330,"elapsed":28,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"80ee00dd-e279-4d74-e3ad-ed5f4bb16bec"},"execution_count":74,"outputs":[{"output_type":"stream","name":"stdout","text":["Number of clusters found: 4\n","Number of noise points:   0 (out out of 1500 total points)\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"8FC7tA8ChXhs"},"execution_count":null,"outputs":[]}]}