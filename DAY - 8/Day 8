].values; b = X.iloc[1].values\n","print('Euclidean (straight line):', round(euclidean(a, b), 2))\n","print('Manhattan (city block)   :', round(cityblock(a, b), 2))\n","print('Cosine (1 - cos angle)   :', round(cosine(a, b), 4))\n","print('\\nEach answers \"how similar?\" differently — the choice shapes every unsupervised result.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Dr82IYZZAR5z","executionInfo":{"status":"ok","timestamp":1781773980435,"user_tz":-330,"elapsed":37,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"b978644d-66ab-4281-a55a-3476a115742a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Euclidean (straight line): 1220.89\n","Manhattan (city block)   : 1493.86\n","Cosine (1 - cos angle)   : 0.0008\n","\n","Each answers \"how similar?\" differently — the choice shapes every unsupervised result.\n"]}]},{"cell_type":"code","source":["from sklearn.metrics import pairwise_distances\n","import numpy as np\n","\n","# Compute distances from reading 0 to every reading\n","distances = pairwise_distances(X.iloc[[0]], X).flatten()\n","\n","# Ignore distance to itself (row 0)\n","distances[0] = np.inf\n","\n","# Index of the nearest neighbour\n","nearest_idx = np.argmin(distances)\n","\n","print(\"Nearest neighbour index:\", nearest_idx)\n","print(\"Distance:\", distances[nearest_idx])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"hTuEB_x2AVFY","executionInfo":{"status":"ok","timestamp":1781778481502,"user_tz":-330,"elapsed":109,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"aedc02de-9137-441f-c2ce-3ed73ed78369"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Nearest neighbour index: 396\n","Distance: 22.840884396192685\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 2A. FEATURE RANGES ARE WILDLY DIFFERENT\n","# -----------------------------------------------------------\n","ranges = (X.max() - X.min()).sort_values(ascending=False)\n","fig, ax = plt.subplots(figsize=(7, 4))\n","ranges.head(10).plot(kind='barh', color='#2D6A9F', ax=ax)\n","ax.set_title('Top-10 sensor ranges (raw units)'); ax.set_xlabel('max - min')\n","plt.tight_layout(); plt.show()\n","print('The widest-range sensor alone would dominate any distance calculation.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":419},"id":"5spPQz9-RX1v","executionInfo":{"status":"ok","timestamp":1781778533490,"user_tz":-330,"elapsed":744,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"55622824-4071-4c5c-f087-53679b839085"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["The widest-range sensor alone would dominate any distance calculation.\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 2B. SCALING CHANGES WHICH READING IS 'NEAREST'\n","# -----------------------------------------------------------\n","from sklearn.preprocessing import StandardScaler\n","Xs = StandardScaler().fit_transform(X)\n","raw_nn = pairwise_distances(X.values[[0]], X.values)[0]\n","scaled_nn = pairwise_distances(Xs[[0]], Xs)[0]\n","raw_nn[0] = scaled_nn[0] = np.inf   # ignore self\n","print('nearest to row 0 on RAW data   :', int(np.argmin(raw_nn)))\n","print('nearest to row 0 on SCALED data:', int(np.argmin(scaled_nn)))\n","print('Different answers — unscaled distance is decided by the biggest-range sensor.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bcfsbJhgRoXU","executionInfo":{"status":"ok","timestamp":1781778540940,"user_tz":-330,"elapsed":19,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"621f62e7-aa8d-4faa-f693-c97569853a4a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["nearest to row 0 on RAW data   : 396\n","nearest to row 0 on SCALED data: 901\n","Different answers — unscaled distance is decided by the biggest-range sensor.\n"]}]},{"cell_type":"code","source":["# 1. raw standard deviations (sorted)\n","\n","import pandas as pd\n","import numpy as np\n","\n","# If X is a NumPy array\n","stds = pd.Series(np.std(X, axis=0), index=range(X.shape[1]))\n","\n","# Sort from largest to smallest\n","print(stds.sort_values(ascending=False))\n","\n","# 2. which dominates & why scaling fixes it:\n","# The sensor with the largest standard deviation dominates the Euclidean\n","# distance because its values vary on a much larger scale than the others.\n","# Since Euclidean distance squares the feature differences, large-scale\n","# sensors contribute disproportionately and can overshadow smaller-scale\n","# sensors. StandardScaler fixes this by transforming each sensor to have\n","# mean = 0 and standard deviation = 1, ensuring that all sensors contribute\n","# equally to the distance calculation."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"TdCP12y5RoJt","executionInfo":{"status":"ok","timestamp":1781778614241,"user_tz":-330,"elapsed":31,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"0f84abbb-1db0-47ca-c63c-1b3fa195f762"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["0    NaN\n","1    NaN\n","2    NaN\n","3    NaN\n","4    NaN\n","5    NaN\n","6    NaN\n","7    NaN\n","8    NaN\n","9    NaN\n","10   NaN\n","11   NaN\n","12   NaN\n","13   NaN\n","14   NaN\n","15   NaN\n","16   NaN\n","17   NaN\n","18   NaN\n","19   NaN\n","20   NaN\n","21   NaN\n","22   NaN\n","23   NaN\n","dtype: float64\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 3A. MANY SENSORS ARE REDUNDANT (CORRELATED)\n","# -----------------------------------------------------------\n","corr = X.corr()\n","fig, ax = plt.subplots(figsize=(8, 6.5))\n","sns.heatmap(corr, cmap='coolwarm', center=0, square=True,\n","            xticklabels=False, yticklabels=True, cbar_kws={'shrink': 0.6}, ax=ax)\n","ax.set_title('Sensor correlation — blocks = redundant groups'); plt.tight_layout(); plt.show()\n","print('Strong blocks mean the 24 sensors carry far fewer than 24 independent signals.')\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":580},"id":"Ta_rD6KaSAX2","executionInfo":{"status":"ok","timestamp":1781778869678,"user_tz":-330,"elapsed":537,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"21ffdfea-8e27-4fd5-e9fa-003142c5b942"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x650 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Strong blocks mean the 24 sensors carry far fewer than 24 independent signals.\n"]}]},{"cell_type":"code","source":["# 1. near-constant sensors\n","\n","import numpy as np\n","import pandas as pd\n","\n","# Raw standard deviations\n","stds = np.std(X, axis=0)\n","\n","# Threshold = 1% of the median standard deviation\n","threshold = 0.01 * np.median(stds)\n","\n","# Indices of near-constant sensors\n","near_constant = np.where(stds < threshold)[0]\n","\n","print(\"Threshold:\", threshold)\n","print(\"Near-constant sensor indices:\", near_constant)\n","print(\"Number of near-constant sensors:\", len(near_constant))\n","\n","# 2. why they hurt:\n","# Near-constant sensors have almost the same value for every observation,\n","# so they contribute little or no useful information for distinguishing\n","# between readings. They still increase the number of dimensions in the\n","# dataset, which makes distance calculations more expensive and can dilute\n","# the influence of informative features. This is a small example of the\n","# curse of dimensionality: as the number of dimensions grows, distances\n","# become less meaningful and models may require more data to identify\n","# useful patterns."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LGnGibBRS-nv","executionInfo":{"status":"ok","timestamp":1781778921541,"user_tz":-330,"elapsed":65,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"155050e2-1674-4d58-813d-f1738fb9b1b6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Threshold: 0.05454556221052135\n","Near-constant sensor indices: []\n","Number of near-constant sensors: 0\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 4A. PCA — HOW MANY COMPONENTS CAPTURE THE VARIANCE?\n","# -----------------------------------------------------------\n","from sklearn.decomposition import PCA\n","pca = PCA().fit(Xs)\n","cum = np.cumsum(pca.explained_variance_ratio_)\n","fig, ax = plt.subplots(figsize=(7, 4))\n","ax.plot(range(1, len(cum) + 1), cum, 'o-', color='#3AAFA9')\n","ax.axhline(0.9, ls='--', color='#C0392B'); ax.set_xlabel('components'); ax.set_ylabel('cumulative variance')\n","ax.set_title('Most variance lives in a few components'); plt.tight_layout(); plt.show()\n","n90 = int(np.argmax(cum >= 0.9) + 1)\n","print(f'{n90} components explain >=90% of the variance (out of {len(sensors)} sensors).')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":419},"id":"XVBNj_vNTLYv","executionInfo":{"status":"ok","timestamp":1781778936013,"user_tz":-330,"elapsed":158,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"75a4bbed-821e-4b32-b763-0d0f5e3e9a95"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["6 components explain >=90% of the variance (out of 24 sensors).\n"]}]},{"cell_type":"code","source":["\n","\n","# -----------------------------------------------------------\n","# 🔹 4B. PROJECT TO 2-D TO SEE THE DATA\n","# -----------------------------------------------------------\n","P2 = PCA(n_components=2).fit_transform(Xs)\n","fig, ax = plt.subplots(figsize=(6, 5))\n","ax.scatter(P2[:, 0], P2[:, 1], s=8, alpha=0.35, color='#2D6A9F')\n","ax.set_xlabel('PC1'); ax.set_ylabel('PC2'); ax.set_title('24 sensors -> 2 components')\n","plt.tight_layout(); plt.show()\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":501},"id":"a-KcjmPATO5j","executionInfo":{"status":"ok","timestamp":1781778986556,"user_tz":-330,"elapsed":719,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"d75ab247-e190-4d75-a486-342af8303e26"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# 1. PCA to n90 components\n","\n","from sklearn.decomposition import PCA\n","\n","# X_scaled = data after StandardScaler\n","# n90 = number of components needed to explain ~90% variance\n","\n","pca = PCA(n_components=n90, random_state=42)\n","X_pca = pca.fit_transform(Xs)\n","\n","print(\"Original shape:\", Xs.shape)\n","print(\"PCA shape:\", X_pca.shape)\n","\n","# 2-3. dimensions dropped, variance kept, why reduce first:\n","# Dimensions dropped = X_scaled.shape[1] - n90\n","# Variance kept = pca.explained_variance_ratio_.sum()\n","#\n","# Example:\n","# dropped = Xs.shape[1] - n90\n","# kept = pca.explained_variance_ratio_.sum()\n","# print(f\"Dropped {dropped} dimensions\")\n","# print(f\"Retained {kept:.2%} of the variance\")\n","#\n","# PCA removes redundant and highly correlated features while preserving\n","# most of the information (variance) in the data. In high-dimensional\n","# spaces, distances become less meaningful (curse of dimensionality),\n","# noise accumulates, and clustering algorithms may struggle to find\n","# well-separated groups. Reducing dimensionality before clustering\n","# improves computational efficiency, reduces noise, and often produces\n","# more meaningful clusters."],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"k-UeE35bTbHi","executionInfo":{"status":"ok","timestamp":1781779057112,"user_tz":-330,"elapsed":8,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"fd1d5996-0407-4a06-be45-33a8e7ce041b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Original shape: (2000, 24)\n","PCA shape: (2000, 6)\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 5A. DISTANCE-FROM-CENTRE FLAGS OUTLIERS\n","# -----------------------------------------------------------\n","centre = Xs.mean(axis=0)\n","dist = np.linalg.norm(Xs - centre, axis=1)\n","thresh = np.mean(dist) + 3 * np.std(dist)\n","outliers = np.where(dist > thresh)[0]\n","print(f'{len(outliers)} readings lie >3 sigma from the centre (candidate anomalies).')\n","fig, ax = plt.subplots(figsize=(6, 5))\n","ax.scatter(P2[:, 0], P2[:, 1], s=8, alpha=0.3, color='#2D6A9F', label='normal')\n","ax.scatter(P2[outliers, 0], P2[outliers, 1], s=45, color='#C0392B', label='anomaly', edgecolor='k')\n","ax.legend(); ax.set_title('Anomalies stand out in PCA space'); plt.tight_layout(); plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":519},"id":"NAZxW1_2TjzE","executionInfo":{"status":"ok","timestamp":1781779061176,"user_tz":-330,"elapsed":838,"user":{"displayName":"Keerthana T","userId":"15423794953416974942"}},"outputId":"a48a71ec-2615-4a9f-cff5-2958d77489f0"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["30 readings lie >3 sigma from the centre (candidate anomalies).\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 1 Axes>"],"image/png":"\n"},"metada